# Copy this file to .env and fill in your token.
# Do NOT commit .env to git.
#
# A fine-grained PAT with "Public repositories (read-only)" is enough — no
# scopes need to be checked. We only read public commit/branch/file data.

# Single token:
GITHUB_TOKEN=

# Token POOL (optional): to multiply the 5000/hr per-token limit, list several
# PATs — comma / space / newline separated. The clients rotate across them and
# park any token that hits its rate limit. Discovery order (merged, de-duped):
#   GITHUB_TOKENS > GITHUB_TOKEN > GITHUB_TOKEN_1, GITHUB_TOKEN_2, ...
# Example:
#   GITHUB_TOKENS=ghp_aaaaaaaa,ghp_bbbbbbbb,ghp_cccccccc
# (numbered form also works:)
#   GITHUB_TOKEN_1=ghp_aaaaaaaa
#   GITHUB_TOKEN_2=ghp_bbbbbbbb
